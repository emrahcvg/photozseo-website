  /* ===== 1.7. BEFORE / AFTER SLIDER ===== */
  .ba {
    padding: 3rem 0 2rem;
  }
  .ba-stage {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    aspect-ratio: 4 / 3;
    border-radius: 20px;
    overflow: hidden;
    user-select: none;
    touch-action: none;
    cursor: ew-resize;
    box-shadow: 0 6px 28px rgba(0,0,0,0.08);
    border: 1px solid #e5e5ea;
    background: #1d1d1f;
  }
  .ba-layer {
    position: absolute;
    inset: 0;
  }
  .ba-before {
    clip-path: inset(0 48% 0 0);
    will-change: clip-path;
    z-index: 2;
  }
  .ba-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ba-inner-after {
    background:
      radial-gradient(circle at 50% 40%, #f8f8fa 0%, #eaeaee 100%);
  }
  .ba-inner-before {
    background:
      linear-gradient(135deg, #2a2520 0%, #4a3f32 100%);
    filter: saturate(0.7) brightness(0.85);
  }
  /* Stylized product silhouette — a fragrance / bottle shape using pure CSS */
  .ba-product {
    position: relative;
    width: 38%;
    height: 64%;
    border-radius: 40px 40px 24px 24px;
    transition: none;
  }
  .ba-product::before,
  .ba-product::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  /* Cap */
  .ba-product::before {
    top: -14%;
    width: 36%;
    height: 18%;
    border-radius: 10px 10px 4px 4px;
  }
  /* Label */
  .ba-product::after {
    top: 55%;
    width: 82%;
    height: 22%;
    border-radius: 6px;
  }

  .ba-product-after {
    background: linear-gradient(145deg, #0071e3 0%, #1B7FE3 50%, #34C759 100%);
    box-shadow:
      inset -10px 0 18px rgba(0,0,0,0.15),
      inset 10px 0 18px rgba(255,255,255,0.2),
      0 18px 30px -8px rgba(0,113,227,0.35);
  }
  .ba-product-after::before {
    background: #1a1a2e;
    box-shadow: inset -4px 0 6px rgba(0,0,0,0.4);
  }
  .ba-product-after::after {
    background: rgba(255,255,255,0.9);
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.1);
  }

  .ba-product-before {
    background: linear-gradient(145deg, #4a5c7a 0%, #3a4a60 50%, #2e6b42 100%);
    transform: rotate(-6deg) scale(0.82) translateY(6%);
    filter: blur(0.6px);
    box-shadow: 0 10px 24px rgba(0,0,0,0.4);
    opacity: 0.9;
  }
  .ba-product-before::before {
    background: #111;
  }
  .ba-product-before::after {
    background: rgba(200,200,200,0.4);
  }

