---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<!-- JSON-LD: SoftwareApplication -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "photoZseo",
  "applicationCategory": "PhotographyApplication",
  "operatingSystem": "iOS, Android",
  "description": "All-in-one product photo optimizer for e-commerce sellers. Resize, compress, SEO-rename, remove backgrounds — all on your phone. Supports 60+ platforms.",
  "offers": [
    { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Free plan" },
    { "@type": "Offer", "price": "6.99", "priceCurrency": "USD", "description": "Pro Monthly" },
    { "@type": "Offer", "price": "39.99", "priceCurrency": "USD", "description": "Pro Yearly" }
  ],
  "featureList": [
    "Product photo camera with crop guides",
    "Auto resize and compress for 60+ platforms",
    "AI-powered SEO filenames and alt text",
    "One-tap platform presets",
    "AI background removal (on-device)",
    "Logo and watermark overlay",
    "Batch export and zip",
    "100% on-device processing"
  ]
})} />

<!-- JSON-LD: FAQPage -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What are the Amazon product photo size requirements?", "acceptedAnswer": { "@type": "Answer", "text": "Amazon requires product images between 1000x1000 and 2000x2000 pixels. photoZseo auto-configures these specs with one tap." }},
    { "@type": "Question", "name": "What is the best universal product photo size?", "acceptedAnswer": { "@type": "Answer", "text": "1200x1200 pixels, square (1:1), white background meets requirements for virtually every platform." }},
    { "@type": "Question", "name": "How many platforms does photoZseo support?", "acceptedAnswer": { "@type": "Answer", "text": "photoZseo supports 60+ platforms including Amazon, Walmart, Etsy, Shopify, eBay, TikTok Shop, Instagram Shopping, Trendyol, Hepsiburada, Poshmark, and more." }}
  ]
})} />

  <!-- ===== 1. HERO ===== -->
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-headline" set:html={t('home.headline')} />
      <p class="hero-sub">{t('home.herosub')}</p>
    </div>

    <div class="hero-transform">
      <div class="hero-file hero-before">
        <div class="file-icon file-icon-bad">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
        </div>
        <div class="file-meta">
          <span class="file-name-bad">IMG_4829.jpg</span>
          <span class="file-detail">5.2 MB &middot; 4032 x 3024</span>
          <div class="file-tags-bad">
            <span>No SEO</span>
            <span>Wrong size</span>
            <span>Too heavy</span>
          </div>
        </div>
      </div>

      <div class="hero-arrow">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>

      <div class="hero-file hero-after">
        <div class="file-icon file-icon-good">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#34C759" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
        </div>
        <div class="file-meta">
          <span class="file-name-good">blue-leather-bag-front.webp</span>
          <span class="file-detail">180 KB &middot; 2000 x 2000</span>
          <div class="file-tags-good">
            <span>SEO-ready</span>
            <span>Amazon</span>
            <span>Etsy</span>
            <span>Shopify</span>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-cta-row">
      <a href="#" class="hero-btn hero-btn-ios">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        App Store
      </a>
      <a href="#" class="hero-btn hero-btn-android">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3 13.83V10.17C3 9.52 3.53 9 4.17 9s1.17.52 1.17 1.17v3.66c0 .65-.52 1.17-1.17 1.17S3 14.48 3 13.83m4.17 2V8.17c0-.65.52-1.17 1.17-1.17h7.33c.65 0 1.17.52 1.17 1.17v7.66c0 .65-.52 1.17-1.17 1.17h-.33v2.83c0 .65-.52 1.17-1.17 1.17s-1.17-.52-1.17-1.17V17h-1.67v2.83c0 .65-.52 1.17-1.17 1.17-.64 0-1.16-.52-1.16-1.17V17h-.34c-.65 0-1.17-.52-1.17-1.17h.01zm.83-9L6.63 4.15a.24.24 0 01.08-.32.24.24 0 01.32.08l1.4 2.72c1.07-.48 2.27-.75 3.57-.75s2.5.27 3.57.75l1.4-2.72a.24.24 0 01.32-.08c.11.06.15.21.08.32L16 6.83c2.39 1.25 3.96 3.52 4 6.17H4c.04-2.65 1.61-4.92 4-6.17M10 9.17a.67.67 0 100-1.34.67.67 0 000 1.34m4 0a.67.67 0 100-1.34.67.67 0 000 1.34M18.67 9c-.65 0-1.17.52-1.17 1.17v3.66c0 .65.52 1.17 1.17 1.17.64 0 1.16-.52 1.16-1.17V10.17c0-.65-.52-1.17-1.16-1.17"/></svg>
        Google Play
      </a>
    </div>
    <p class="hero-footnote">{t('home.footnote')}</p>
  </section>

  <!-- ===== 2. PLATFORM BAND ===== -->
  <section class="platforms-band">
    <p class="band-label">{t('home.bandlabel')}</p>
    <div class="band-scroll">
      <div class="band-track">
        <span class="band-logo">Amazon</span>
        <span class="band-logo">Etsy</span>
        <span class="band-logo">Shopify</span>
        <span class="band-logo">eBay</span>
        <span class="band-logo">TikTok Shop</span>
        <span class="band-logo">Instagram</span>
        <span class="band-logo">Trendyol</span>
        <span class="band-logo">Hepsiburada</span>
        <span class="band-logo">Pinterest</span>
        <span class="band-logo">Facebook</span>
        <span class="band-logo">Shopee</span>
        <span class="band-logo">AliExpress</span>
        <span class="band-logo">Zalando</span>
        <span class="band-logo">Mercado Libre</span>
        <span class="band-logo">Walmart</span>
        <span class="band-logo">N11</span>
        <span class="band-logo">WhatsApp</span>
        <!-- duplicate for seamless loop -->
        <span class="band-logo">Amazon</span>
        <span class="band-logo">Etsy</span>
        <span class="band-logo">Shopify</span>
        <span class="band-logo">eBay</span>
        <span class="band-logo">TikTok Shop</span>
        <span class="band-logo">Instagram</span>
        <span class="band-logo">Trendyol</span>
        <span class="band-logo">Hepsiburada</span>
        <span class="band-logo">Pinterest</span>
        <span class="band-logo">Facebook</span>
        <span class="band-logo">Shopee</span>
        <span class="band-logo">AliExpress</span>
        <span class="band-logo">Zalando</span>
        <span class="band-logo">Mercado Libre</span>
        <span class="band-logo">Walmart</span>
        <span class="band-logo">N11</span>
        <span class="band-logo">WhatsApp</span>
      </div>
    </div>
  </section>

  <!-- ===== 3. HOW IT WORKS ===== -->
  <section class="how" id="features">
    <h2 class="section-title">{t('home.howitworks')}</h2>
    <p class="section-sub">{t('home.howitworks.sub')}</p>

    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#1d1d1f" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
        </div>
        <h3>{t('home.step.shoot')}</h3>
        <p>{t('home.step.shoot.desc')}</p>
      </div>

      <div class="step-connector">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d2d2d7" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>

      <div class="step">
        <div class="step-num">2</div>
        <div class="step-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#1d1d1f" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </div>
        <h3>{t('home.step.optimize')}</h3>
        <p>{t('home.step.optimize.desc')}</p>
      </div>

      <div class="step-connector">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d2d2d7" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>

      <div class="step">
        <div class="step-num">3</div>
        <div class="step-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#1d1d1f" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
        </div>
        <h3>{t('home.step.sell')}</h3>
        <p>{t('home.step.sell.desc')}</p>
      </div>
    </div>

    <div class="how-comparison">
      <div class="compare-item compare-old">
        <span class="compare-label">{t('home.compare.without')}</span>
        <span class="compare-value">{t('home.compare.without.val')}</span>
      </div>
      <div class="compare-item compare-new">
        <span class="compare-label">{t('home.compare.with')}</span>
        <span class="compare-value">{t('home.compare.with.val')}</span>
      </div>
    </div>
  </section>

  <!-- ===== 4. FEATURES ===== -->
  <section class="features">
    <h2 class="section-title">{t('home.features.title')}</h2>
    <p class="section-sub">{t('home.features.sub')}</p>

    <div class="feature-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0071e3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
        </div>
        <h3>{t('features.camera.title')}</h3>
        <p>{t('features.camera.desc')}</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0071e3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
        </div>
        <h3>{t('features.resize.title')}</h3>
        <p>{t('features.resize.desc')}</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0071e3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </div>
        <h3>{t('features.seo.title')}</h3>
        <p>{t('features.seo.desc')}</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0071e3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </div>
        <h3>{t('features.bgremoval.title')}</h3>
        <p>{t('features.bgremoval.desc')}</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0071e3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3>{t('features.logo.title')}</h3>
        <p>{t('features.logo.desc')}</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0071e3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
        </div>
        <h3>{t('features.batch.title')}</h3>
        <p>{t('features.batch.desc')}</p>
      </div>
    </div>

    <div class="privacy-bar">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      <span>{t('home.privacy')}</span>
    </div>
  </section>

  <!-- ===== 5. PRICING ===== -->
  <section class="pricing" id="pricing">
    <h2 class="section-title">{t('pricing.title')}</h2>
    <p class="section-sub">{t('home.pricing.sub')}</p>

    <div class="pricing-layout">
      <!-- Free -->
      <div class="price-card">
        <h3>{t('pricing.free')}</h3>
        <div class="price-amount">{t('pricing.free.price')}</div>
        <ul class="price-features">
          <li class="feat-yes">{t('pricing.free.f1')}</li>
          <li class="feat-yes">{t('pricing.free.f4')}</li>
          <li class="feat-no">{t('pricing.free.f2')}</li>
          <li class="feat-no">{t('pricing.free.f3')}</li>
        </ul>
      </div>

      <!-- Pro -->
      <div class="price-card price-card-pro">
        <div class="pro-badge">Pro</div>
        <h3>{t('home.pro.title')}</h3>
        <div class="pro-features">
          <li class="feat-yes">{t('home.pro.f1')}</li>
          <li class="feat-yes">{t('home.pro.f2')}</li>
          <li class="feat-yes">{t('home.pro.f3')}</li>
          <li class="feat-yes">{t('home.pro.f4')}</li>
          <li class="feat-yes">{t('home.pro.f5')}</li>
        </div>

        <div class="plan-options">
          <div class="plan-option">
            <span class="plan-name">{t('pricing.weekly')}</span>
            <span class="plan-price">{t('pricing.weekly.price')}{t('pricing.weekly.per')}</span>
          </div>
          <div class="plan-option">
            <span class="plan-name">{t('pricing.monthly')}</span>
            <span class="plan-price">{t('pricing.monthly.price')}{t('pricing.monthly.per')}</span>
            <span class="plan-trial">{t('home.trial')}</span>
          </div>
          <div class="plan-option">
            <span class="plan-name">{t('pricing.quarterly')}</span>
            <span class="plan-price">{t('pricing.quarterly.price')}{t('pricing.quarterly.per')}</span>
            <span class="plan-save">{t('pricing.quarterly.badge')}</span>
          </div>
          <div class="plan-option plan-option-best">
            <span class="plan-name">{t('pricing.yearly')}</span>
            <span class="plan-price">{t('pricing.yearly.price')}{t('pricing.yearly.per')}</span>
            <span class="plan-save plan-save-best">{t('pricing.yearly.badge')}</span>
            <span class="plan-sub">{t('pricing.yearly.sub')}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 6. FINAL CTA ===== -->
  <section class="final-cta">
    <h2>{t('cta.title')}</h2>
    <p>{t('cta.desc')}</p>
    <div class="hero-cta-row">
      <a href="#" class="hero-btn hero-btn-ios">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        App Store
      </a>
      <a href="#" class="hero-btn hero-btn-android">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3 13.83V10.17C3 9.52 3.53 9 4.17 9s1.17.52 1.17 1.17v3.66c0 .65-.52 1.17-1.17 1.17S3 14.48 3 13.83m4.17 2V8.17c0-.65.52-1.17 1.17-1.17h7.33c.65 0 1.17.52 1.17 1.17v7.66c0 .65-.52 1.17-1.17 1.17h-.33v2.83c0 .65-.52 1.17-1.17 1.17s-1.17-.52-1.17-1.17V17h-1.67v2.83c0 .65-.52 1.17-1.17 1.17-.64 0-1.16-.52-1.16-1.17V17h-.34c-.65 0-1.17-.52-1.17-1.17h.01zm.83-9L6.63 4.15a.24.24 0 01.08-.32.24.24 0 01.32.08l1.4 2.72c1.07-.48 2.27-.75 3.57-.75s2.5.27 3.57.75l1.4-2.72a.24.24 0 01.32-.08c.11.06.15.21.08.32L16 6.83c2.39 1.25 3.96 3.52 4 6.17H4c.04-2.65 1.61-4.92 4-6.17M10 9.17a.67.67 0 100-1.34.67.67 0 000 1.34m4 0a.67.67 0 100-1.34.67.67 0 000 1.34M18.67 9c-.65 0-1.17.52-1.17 1.17v3.66c0 .65.52 1.17 1.17 1.17.64 0 1.16-.52 1.16-1.17V10.17c0-.65-.52-1.17-1.16-1.17"/></svg>
        Google Play
      </a>
    </div>
  </section>

<style>
  /* ===== GLOBAL ===== */
  .section-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: #1d1d1f;
    text-align: center;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .section-sub {
    font-size: 1.1rem;
    color: #86868b;
    text-align: center;
    margin-bottom: 3rem;
  }

  /* ===== 1. HERO ===== */
  .hero {
    text-align: center;
    padding: 5rem 1.5rem 3rem;
    background: #fff;
    border-radius: 20px;
    margin: -2rem -2rem 0;
  }
  .hero-headline {
    font-size: 3.5rem;
    font-weight: 700;
