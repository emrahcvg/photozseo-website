---
import Layout from '../../layouts/Layout.astro';
import { languages, defaultLang, type Lang, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
---

<Layout title={t('hero.tagline').slice(0, 50)} lang={lang}>
  <section class="hero">
    <h1>{t('hero.title')}</h1>
    <p class="tagline">{t('hero.tagline')}</p>
    <div class="badges">
      <a href="#" class="badge badge-ios">{t('hero.cta')}</a>
      <a href="#" class="badge badge-android">{t('hero.cta.android')}</a>
    </div>
  </section>

  <section class="platforms">
    <h2>{t('platforms.title')}</h2>
    <div class="platform-grid">
      <div class="platform">Amazon</div>
      <div class="platform">Etsy</div>
      <div class="platform">Shopify</div>
      <div class="platform">Trendyol</div>
      <div class="platform">Instagram</div>
      <div class="platform">TikTok</div>
      <div class="platform">Web</div>
    </div>
  </section>

  <section class="features">
    <h2>{t('features.title')}</h2>
    <div class="feature-grid">
      <div class="feature"><h3>{t('features.camera.title')}</h3><p>{t('features.camera.desc')}</p></div>
      <div class="feature"><h3>{t('features.archive.title')}</h3><p>{t('features.archive.desc')}</p></div>
      <div class="feature"><h3>{t('features.resize.title')}</h3><p>{t('features.resize.desc')}</p></div>
      <div class="feature"><h3>{t('features.seo.title')}</h3><p>{t('features.seo.desc')}</p></div>
      <div class="feature"><h3>{t('features.presets.title')}</h3><p>{t('features.presets.desc')}</p></div>
      <div class="feature"><h3>{t('features.video.title')}</h3><p>{t('features.video.desc')}</p></div>
      <div class="feature"><h3>{t('features.bgremoval.title')}</h3><p>{t('features.bgremoval.desc')}</p></div>
      <div class="feature"><h3>{t('features.logo.title')}</h3><p>{t('features.logo.desc')}</p></div>
      <div class="feature"><h3>{t('features.batch.title')}</h3><p>{t('features.batch.desc')}</p></div>
      <div class="feature"><h3>{t('features.ondevice.title')}</h3><p>{t('features.ondevice.desc')}</p></div>
    </div>
  </section>

  <section class="pricing" id="pricing">
    <h2>{t('pricing.title')}</h2>
    <div class="plan-grid">
      <div class="plan">
        <h3>{t('pricing.free')}</h3>
        <p class="price">{t('pricing.free.price')}</p>
        <ul><li>{t('pricing.free.f1')}</li><li>{t('pricing.free.f2')}</li><li>{t('pricing.free.f3')}</li><li>{t('pricing.free.f4')}</li></ul>
      </div>
      <div class="plan featured">
        <span class="badge-label">{t('pricing.lifetime.badge')}</span>
        <h3>{t('pricing.lifetime')}</h3>
        <p class="price">{t('pricing.lifetime.price')}</p>
        <p class="price-sub">{t('pricing.lifetime.sub')}</p>
        <ul><li>{t('pricing.lifetime.f1')}</li><li>{t('pricing.lifetime.f2')}</li><li>{t('pricing.lifetime.f3')}</li><li>{t('pricing.lifetime.f4')}</li><li>{t('pricing.lifetime.f5')}</li><li>{t('pricing.lifetime.f6')}</li></ul>
      </div>
      <div class="plan">
        <h3>{t('pricing.monthly')}</h3>
        <p class="price">{t('pricing.monthly.price')}<span>{t('pricing.monthly.per')}</span></p>
        <p class="price-sub">{t('pricing.monthly.sub')}</p>
        <ul><li>{t('pricing.monthly.f1')}</li><li>{t('pricing.monthly.f2')}</li></ul>
      </div>
      <div class="plan">
        <h3>{t('pricing.yearly')}</h3>
        <p class="price">{t('pricing.yearly.price')}<span>{t('pricing.yearly.per')}</span></p>
        <p class="price-sub">{t('pricing.yearly.sub')}</p>
        <ul><li>{t('pricing.yearly.f1')}</li><li>{t('pricing.yearly.f2')}</li></ul>
      </div>
    </div>
  </section>

  <section class="cta">
    <h2>{t('cta.title')}</h2>
    <p>{t('cta.desc')}</p>
    <div class="badges">
      <a href="#" class="badge badge-ios">{t('hero.cta')}</a>
      <a href="#" class="badge badge-android">{t('hero.cta.android')}</a>
    </div>
  </section>
</Layout>

<style>
  .hero { text-align: center; padding: 4rem 0 3rem; }
  .tagline { font-size: 1.2rem; color: #666; max-width: 540px; margin: 0 auto 2rem; }
  .badges { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .badge { display: inline-block; padding: 0.75rem 1.5rem; color: #fff; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 0.95rem; }
  .badge-ios { background: #1a1a1a; }
  .badge-ios:hover { background: #333; }
  .badge-android { background: #01875f; }
  .badge-android:hover { background: #017a56; }
  .platforms { text-align: center; padding: 2rem 0; }
  .platform-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 1rem; }
  .platform { padding: 0.5rem 1.25rem; background: #fff; border: 1px solid #e5e5e5; border-radius: 20px; font-size: 0.9rem; color: #444; font-weight: 500; }
  .features { padding: 2rem 0; }
  .features h2 { text-align: center; }
  .feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1.5rem; }
  .feature { background: #fff; padding: 1.5rem; border-radius: 12px; border: 1px solid #e5e5e5; }
  .feature h3 { font-size: 1.05rem; margin-bottom: 0.5rem; color: #1a1a1a; }
  .feature p { font-size: 0.9rem; margin: 0; }
  .pricing { padding: 2rem 0; }
  .pricing h2 { text-align: center; }
  .plan-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin-top: 1.5rem; }
  .plan { background: #fff; padding: 1.5rem; border-radius: 12px; border: 1px solid #e5e5e5; position: relative; }
  .plan.featured { border: 2px solid #1a1a1a; }
  .badge-label { position: absolute; top: -0.75rem; left: 50%; transform: translateX(-50%); background: #1a1a1a; color: #fff; font-size: 0.75rem; padding: 0.2rem 0.75rem; border-radius: 10px; font-weight: 600; white-space: nowrap; }
  .plan h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .price { font-size: 2rem; font-weight: 700; color: #1a1a1a; margin-bottom: 0.25rem; }
  .price span { font-size: 1rem; font-weight: 400; color: #666; }
  .price-sub { font-size: 0.85rem; color: #888; margin-bottom: 1rem; }
  .plan ul { list-style: none; padding: 0; }
  .plan li { font-size: 0.9rem; padding: 0.25rem 0; color: #444; }
  .plan li::before { content: "\2713 "; color: #22c55e; font-weight: 700; }
  .cta { text-align: center; padding: 3rem 0; }
  .cta p { margin-bottom: 1.5rem; }
  @media (max-width: 600px) { .feature-grid, .plan-grid { grid-template-columns: 1fr; } }
</style>
