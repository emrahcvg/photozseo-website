---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { defaultLang, useTranslations } from '../../i18n/ui';

const lang = defaultLang;
const t = useTranslations(lang);

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = t('blog.title');
---

<Layout title={title} lang={lang}>
  <section class="blog-hero">
    <span class="blog-kicker">{t('blog.kicker')}</span>
    <h1>{t('blog.title')}</h1>
    <p>{t('blog.sub')}</p>
  </section>

  <ul class="blog-list">
    {posts.map((post) => (
      <li class="blog-card">
        <a href={`/blog/${post.id}`}>
          <div class="blog-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
            <span>· {post.data.readingMinutes} min read</span>
          </div>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <div class="blog-tags">
            {post.data.tags.map((tag) => <span class="blog-tag">{tag}</span>)}
          </div>
        </a>
      </li>
    ))}
  </ul>

  <style>
    .blog-hero {
      text-align: center;
      padding: 3rem 1rem 2.5rem;
      background: linear-gradient(180deg, #fff 0%, #f5f5f7 100%);
      border-radius: 20px;
      margin: -2rem -2rem 2rem;
    }
    .blog-kicker {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #0071e3;
      background: rgba(0,113,227,0.1);
      padding: 0.25rem 0.7rem;
      border-radius: 999px;
      margin-bottom: 1rem;
    }
    .blog-hero h1 {
      font-size: 2.4rem;
      font-weight: 700;
      color: #1d1d1f;
      letter-spacing: -0.02em;
      margin-bottom: 0.75rem;
    }
    .blog-hero p {
      color: #555;
      font-size: 1.05rem;
      max-width: 520px;
      margin: 0 auto;
    }
    .blog-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      max-width: 720px;
      margin: 0 auto;
    }
    .blog-card a {
      display: block;
      background: #fff;
      border: 1px solid #e5e5ea;
      border-radius: 16px;
      padding: 1.5rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s, transform 0.2s;
    }
    .blog-card a:hover {
      border-color: #0071e3;
      transform: translateY(-2px);
    }
    .blog-meta {
      display: flex;
      gap: 0.4rem;
      font-size: 0.78rem;
      color: #86868b;
      margin-bottom: 0.6rem;
    }
    .blog-card h2 {
      font-size: 1.15rem;
      font-weight: 600;
      color: #1d1d1f;
      margin: 0 0 0.5rem;
      line-height: 1.35;
    }
    .blog-card p {
      font-size: 0.9rem;
      color: #555;
      margin: 0 0 0.85rem;
      line-height: 1.55;
    }
    .blog-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }
    .blog-tag {
      font-size: 0.7rem;
      font-weight: 500;
      background: #f5f5f7;
      color: #86868b;
      padding: 0.2rem 0.55rem;
      border-radius: 6px;
    }
    @media (max-width: 768px) {
      .blog-hero {
        margin: -1rem -1rem 1.5rem;
        padding: 2rem 1rem;
      }
      .blog-hero h1 { font-size: 1.8rem; }
    }
  </style>
</Layout>
