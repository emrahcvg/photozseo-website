---
import { languages, rtlLanguages, defaultLang, type Lang, useTranslations } from '../i18n/ui';

interface Props {
  title: string;
  lang?: Lang;
}

const { title, lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const isRtl = rtlLanguages.includes(lang);
const prefix = lang === defaultLang ? '' : `/${lang}`;
---

<!doctype html>
<html lang={lang} dir={isRtl ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="photoZseo — The all-in-one product photo optimizer for e-commerce sellers. Shoot, resize, compress, SEO-rename, remove backgrounds & push to Shopify. No computer needed. 60+ platform presets." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1B7FE3" />
    <link rel="canonical" href={`https://photozseo.com${Astro.url.pathname}`} />
    <title>{title} | photoZseo</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | photoZseo`} />
    <meta property="og:description" content="Product photo optimizer for 60+ e-commerce platforms. Resize, compress, SEO-rename, remove backgrounds — all on your phone." />
    <meta property="og:url" content={`https://photozseo.com${Astro.url.pathname}`} />
    <meta property="og:site_name" content="photoZseo" />
    <meta property="og:locale" content={lang} />
    <meta property="og:image" content="https://photozseo.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | photoZseo`} />
    <meta name="twitter:description" content="Product photo optimizer for 60+ e-commerce platforms. No computer needed." />
    <meta name="twitter:image" content="https://photozseo.com/og-image.png" />

    <!-- SEO extras -->
    <meta name="robots" content="index, follow" />
    <meta name="keywords" content="product photo optimizer, e-commerce photo, SEO filename, image resize, background removal, Shopify push, Amazon photo size, Etsy image specs, TikTok Shop photo, Instagram Shopping, product photography app" />
    <link rel="sitemap" href="/sitemap.xml" />
  </head>
  <body>
    <nav>
      <a href={`${prefix}/`} class="logo">
        <span class="logo-icon">📷</span> photo<span class="logo-z">Z</span>seo
      </a>
      <div class="nav-links">
        <a href={`${prefix}/#features`}>{t('nav.features')}</a>
        <a href={`${prefix}/#pricing`}>{t('nav.pricing')}</a>
        <a href={`${prefix}/support`}>{t('nav.support')}</a>
      </div>
      <div class="lang-picker">
        <select onchange={`window.location.href=this.value`}>
          {Object.entries(languages).map(([code, name]) => {
            const langPrefix = code === defaultLang ? '' : `/${code}`;
            const currentPath = Astro.url.pathname.replace(/^\/(en|zh|tr|es|de|ja|pt|hi|ur|ar|fa|ko)/, '');
            return (
              <option value={`${langPrefix}${currentPath || '/'}`} selected={code === lang}>
                {name}
              </option>
            );
          })}
        </select>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-links">
        <a href={`${prefix}/privacy`}>{t('footer.privacy')}</a>
        <a href={`${prefix}/terms`}>{t('footer.terms')}</a>
        <a href={`${prefix}/support`}>{t('footer.support')}</a>
        <a href={`${prefix}/delete-account`}>{t('footer.delete')}</a>
      </div>
      <p>&copy; {new Date().getFullYear()} photoZseo. {t('footer.rights')}</p>
    </footer>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        color: #1a1a2e;
        line-height: 1.6;
        background: #F2F2F7;
      }
      [dir="rtl"] {
        font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
      }
      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2rem;
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid #E5E7EB;
        max-width: 960px;
        margin: 0 auto;
        gap: 1rem;
        position: sticky;
        top: 0;
        z-index: 100;
      }
      .logo {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1a1a2e;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.3rem;
      }
      .logo-icon {
        font-size: 1.3rem;
      }
      .logo-z {
        color: #1B7FE3;
      }
      .nav-links {
        display: flex;
        gap: 1.5rem;
      }
      .nav-links a {
        color: #666;
        text-decoration: none;
        font-size: 0.9rem;
      }
      .nav-links a:hover {
        color: #1a1a1a;
      }
      .lang-picker select {
        padding: 0.3rem 0.5rem;
        border: 1px solid #ddd;
        border-radius: 6px;
        background: #fff;
        font-size: 0.85rem;
        color: #444;
        cursor: pointer;
      }
      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem;
      }
      footer {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem;
        text-align: center;
        color: #999;
        font-size: 0.85rem;
        border-top: 1px solid #e5e5e5;
      }
      .footer-links {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
      }
      .footer-links a {
        color: #999;
        text-decoration: none;
        font-size: 0.85rem;
      }
      .footer-links a:hover {
        color: #666;
      }
      h1 {
        font-size: 2rem;
        margin-bottom: 1.5rem;
      }
      h2 {
        font-size: 1.4rem;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
      }
      p, li {
        margin-bottom: 0.75rem;
        color: #444;
      }
      ul {
        padding-left: 1.5rem;
      }
      [dir="rtl"] ul {
        padding-left: 0;
        padding-right: 1.5rem;
      }
      a {
        color: #0066cc;
      }
      @media (max-width: 600px) {
        nav {
          flex-direction: column;
          gap: 0.75rem;
        }
        .nav-links {
          gap: 1rem;
          flex-wrap: wrap;
          justify-content: center;
        }
      }
    </style>
  </body>
</html>
